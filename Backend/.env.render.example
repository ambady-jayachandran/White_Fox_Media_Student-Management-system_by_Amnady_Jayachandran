# Render production environment variables.
# Do not commit a real .env with live secrets.

SECRET_KEY=generate-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=your-backend-name.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

DB_ENGINE=postgresql
DB_NAME=your_render_postgres_database
DB_USER=your_render_postgres_user
DB_PASSWORD=your_render_postgres_password
DB_HOST=your_render_postgres_host
DB_PORT=5432

ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
